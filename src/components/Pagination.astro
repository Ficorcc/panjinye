---
import '../styles/pagination.css';

interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string;
}

const { currentPage, totalPages, baseUrl } = Astro.props;

const hasPrev = currentPage > 1;
const hasNext = currentPage < totalPages;

const prevUrl = currentPage === 2 ? baseUrl : `${baseUrl}page/${currentPage - 1}/`;
const nextUrl = `${baseUrl}page/${currentPage + 1}/`;
---

{totalPages > 1 && (
  <nav class="pagination">
    {currentPage > 1 && (
      <a href={baseUrl} class="pagination-first" aria-label="第一页">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="17 18 11 12 17 6"/>
          <line x1="7" y1="6" x2="7" y2="18"/>
        </svg>
      </a>
    )}
    
    {hasPrev ? (
      <a href={prevUrl} class="pagination-prev" aria-label="上一页">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
      </a>
    ) : (
      <span class="pagination-prev disabled" aria-label="上一页">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
      </span>
    )}
    
    <span class="pagination-info">
      {currentPage} / {totalPages}
    </span>
    
    {hasNext ? (
      <a href={nextUrl} class="pagination-next" aria-label="下一页">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </a>
    ) : (
      <span class="pagination-next disabled" aria-label="下一页">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </span>
    )}
    
    {currentPage < totalPages && (
      <a href={`${baseUrl}page/${totalPages}/`} class="pagination-last" aria-label="最后一页">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="17" y1="6" x2="17" y2="18"/>
          <polyline points="7 6 13 12 7 18"/>
        </svg>
      </a>
    )}
  </nav>
)}
