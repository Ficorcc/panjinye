---
import '../styles/post-card.css';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, date, category, views = 0, comments = 0 } = post.data;

const dateObj = new Date(date);
const month = dateObj.toLocaleDateString('en-US', { month: 'short' }).toUpperCase();
const day = dateObj.getDate();
const yearTime = dateObj.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
  hour: '2-digit',
  minute: '2-digit'
});

const summary = post.body 
  ? post.body.replace(/[#*`{}[\]()<>]/g, '').replace(/\s+/g, ' ').trim().split(/(?<=[。.!?])/).slice(0, 3).join('') 
  : '';
---

<article class="post-card">
  <div class="post-meta">
    <time class="post-date" datetime={date.toISOString()}>
      <span class="date-month">{month}</span>
      <span class="date-day">{day}</span>
      <span class="date-year-time">{yearTime}</span>
    </time>
  </div>
  
  <div class="post-content">
    <h2 class="post-title">
      <a href={`/blog/${post.slug}/`}>{title}</a>
    </h2>
    
    <div class="post-stats">
      <span class="stat">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
          <circle cx="12" cy="12" r="3"/>
        </svg>
        {views}
      </span>
      <span class="stat">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
        </svg>
        {comments}
      </span>
      {category && (
        <span class="post-category">
          <a href={`/categories/${category}/`}>{category}</a>
        </span>
      )}
    </div>
    
    <div class="post-summary">
      <p>{summary}...</p>
    </div>
  </div>
</article>